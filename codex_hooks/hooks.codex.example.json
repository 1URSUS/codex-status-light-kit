{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /absolute/path/to/codex-status-light-kit/codex_hooks/send_signal.py",
            "commandWindows": "python C:\\absolute\\path\\to\\codex-status-light-kit\\codex_hooks\\send_signal.py",
            "timeout": 12,
            "statusMessage": "Status light: session start"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /absolute/path/to/codex-status-light-kit/codex_hooks/send_signal.py",
            "commandWindows": "python C:\\absolute\\path\\to\\codex-status-light-kit\\codex_hooks\\send_signal.py",
            "timeout": 12,
            "statusMessage": "Status light: thinking"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /absolute/path/to/codex-status-light-kit/codex_hooks/send_signal.py",
            "commandWindows": "python C:\\absolute\\path\\to\\codex-status-light-kit\\codex_hooks\\send_signal.py",
            "timeout": 12,
            "statusMessage": "Status light: tool running"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /absolute/path/to/codex-status-light-kit/codex_hooks/send_signal.py",
            "commandWindows": "python C:\\absolute\\path\\to\\codex-status-light-kit\\codex_hooks\\send_signal.py",
            "timeout": 12,
            "statusMessage": "Status light: waiting for approval"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /absolute/path/to/codex-status-light-kit/codex_hooks/send_signal.py",
            "commandWindows": "python C:\\absolute\\path\\to\\codex-status-light-kit\\codex_hooks\\send_signal.py",
            "timeout": 12,
            "statusMessage": "Status light: tool finished"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /absolute/path/to/codex-status-light-kit/codex_hooks/send_signal.py",
            "commandWindows": "python C:\\absolute\\path\\to\\codex-status-light-kit\\codex_hooks\\send_signal.py",
            "timeout": 12,
            "statusMessage": "Status light: subagent stopped"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /absolute/path/to/codex-status-light-kit/codex_hooks/send_signal.py",
            "commandWindows": "python C:\\absolute\\path\\to\\codex-status-light-kit\\codex_hooks\\send_signal.py",
            "timeout": 12,
            "statusMessage": "Status light: turn complete"
          }
        ]
      }
    ]
  }
}
